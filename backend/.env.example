# ══════════════════════════════════════════════════════════════
# PadiGuard AI — Backend Environment Configuration
# Shared by both Diagnosis (FastAPI) and Swarm (Genkit) services
# ══════════════════════════════════════════════════════════════

# ── Google Cloud (Diagnosis) ──────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCS_BUCKET_NAME=disease_dataset_pd

# ── Vertex AI Vector Search (Diagnosis) ───────────────────────
VECTOR_SEARCH_INDEX_ENDPOINT=your-index-endpoint
VECTOR_SEARCH_DEPLOYED_INDEX_ID=your-deployed-index-id
VECTOR_SEARCH_CONFIDENCE_THRESHOLD=0.65
VECTOR_SEARCH_FAST_MATCH_THRESHOLD=0.85

# ── Gemini (Diagnosis) ───────────────────────────────────────
GEMINI_MODEL_NAME=gemini-2.0-flash

# ── Google AI API Key (Swarm) ─────────────────────────────────
GOOGLE_GENAI_API_KEY=YOUR_GEMINI_API_KEY_PLACEHOLDER

# ── Tomorrow.io Weather API (Swarm) ──────────────────────────
TOMORROW_IO_API_KEY=YOUR_TOMORROW_IO_API_KEY_PLACEHOLDER

# ── ManaMurah MCP Server (Swarm) ─────────────────────────────
MCP_SERVER_URL=https://your-mcp-server.run.app/sse

# ── Firebase / GCP Credentials (Shared) ──────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
