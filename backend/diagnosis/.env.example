# ── Google Cloud Core ──────────────────────────────────────────────────
GCP_PROJECT_ID="your-gcp-project-id"
GCP_REGION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS="path/to/service-account-key.json"

# ── Vertex AI Multimodal Embedding ────────────────────────────────────
EMBEDDING_MODEL="multimodalembedding@001"
EMBEDDING_DIMENSION=1408

# ── Vertex AI Vector Search ───────────────────────────────────────────
VECTOR_SEARCH_INDEX_ENDPOINT="projects/{project}/locations/{region}/indexEndpoints/{endpoint_id}"
VECTOR_SEARCH_DEPLOYED_INDEX_ID="your-deployed-index-id"
VECTOR_SEARCH_CONFIDENCE_THRESHOLD=0.65
VECTOR_SEARCH_FAST_MATCH_THRESHOLD=0.85

# ── Vertex AI Gemini ──────────────────────────────────────────────────
GEMINI_MODEL_NAME="gemini-2.0-flash"

# ── Cloud Firestore ───────────────────────────────────────────────────
FIRESTORE_GRID_COLLECTION="grids"
FIRESTORE_REPORT_COLLECTION="scanReports"

# ── Pipeline ──────────────────────────────────────────────────────────
DEFAULT_TOP_K=5
