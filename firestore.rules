rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function writesOwnData() {
      return signedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    function isLegacyConversationOwner(data) {
      return signedIn() && (
        data.ownerUid == request.auth.uid ||
        data.userId == request.auth.uid ||
        data.uid == request.auth.uid
      );
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/grids/{gridId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/conversations/{conversationId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/scanCaptures/{captureId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn() && request.auth.uid == userId && request.resource.data.ownerUid == userId;
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /conversations/{conversationId} {
      allow create: if isLegacyConversationOwner(request.resource.data);
      allow read, delete: if isLegacyConversationOwner(resource.data);
      allow update: if isLegacyConversationOwner(resource.data) && isLegacyConversationOwner(request.resource.data);
    }

    match /grids/{gridId} {
      allow create: if writesOwnData();
      allow read: if isOwner();
      allow update: if isOwner() && writesOwnData();
      allow delete: if isOwner();
    }

    match /scanReports/{reportId} {
      allow read, write: if signedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
