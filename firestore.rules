rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function writesOwnData() {
      return signedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /grids/{gridId} {
      allow create: if writesOwnData();
      allow read: if isOwner();
      allow update: if isOwner() && writesOwnData();
      allow delete: if isOwner();
    }

    match /scanReports/{reportId} {
      allow read, write: if signedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
