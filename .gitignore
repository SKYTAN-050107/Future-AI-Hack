# macOS
.DS_Store

# Node modules and logs
**/node_modules/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build artifacts
**/dist/
**/dev-dist/

# Allow tracked frontend hosting artifacts while keeping other dist outputs ignored
!frontend/dist/
frontend/dist/**
!frontend/dist/index.html
!frontend/dist/sw.js

# Environment and secrets (all workspaces)
.env
.env.*
!.env.example
!.env.template
!.env.sample
!.env.example

# Credential and key material
*.pem
*.key
*.p12
*.jks
*.keystore
*.crt
*.cer
*.pfx
serviceAccount*.json
firebase-adminsdk*.json
**/service-account.json
**/service-account*.json

# Firebase local state
.firebase/
.firebase-*/
.firebaserc.local
.runtimeconfig.json

